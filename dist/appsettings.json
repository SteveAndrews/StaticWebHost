{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "StaticWebHost": {
        "Mode": "BuildAndStatus",
        "PollingIntervalSeconds": 2,
        "StatusIndicatorUrlPaths": [
            "/",
            "/index.html"
        ],
        // Downdload esbuild from: https://github.com/evanw/esbuild/releases
        "EsbuildPath": "/_sys/esbuild.exe",
        "EsbuildCompileArgs": "--bundle --minify --format=esm --target=es2020",
        "TypeScriptRoot": "/dev/src",
        "TypeScriptCompilationFiles": [
            {
                "entry": "/dev/src/main/app.ts",
                "output": "/wwwroot/js/app.bundle.min.js"
            }
        ],
        "ScssCompilationPaths": [
            {
                "scanDir": "/dev/styles",
                "output": "/wwwroot/styles"
            }
        ],
        "StaticCopyExcludePaths": [
            "/dev/src",
            "/dev/styles"
        ]
        //"CustomCompilationPaths": [
        //    {
        //        "tool": "/path/to/tool.exe",
        //        "args": "{input} --output {output}",
        //        "scanDir": "/dev/markdown",
        //        "output": "/wwwroot/content",
        //        "extension": ".md",
        //        "outputExtension": ".html"
        //    }
        //]
    }
}
